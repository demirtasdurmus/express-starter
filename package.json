{
  "name": "express-starter",
  "version": "1.0.0",
  "description": "Express Starter Boilerplate",
  "keywords": [
    "express",
    "typescript",
    "starter",
    "boilerplate"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev:tsc": "tsc --watch --preserveWatchOutput -p tsconfig.build.json",
    "dev:node": "node --enable-source-maps --watch dist/index.js",
    "dev": "pnpm run \"/dev:/\"",
    "build": "tsc --pretty -p tsconfig.build.json && node scripts/minify-assets.js",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:int": "jest --config ./jest-int.config.ts",
    "test:int:watch": "jest --config ./jest-int.config.ts --watchAll --verbose",
    "test:coverage": "jest --config ./jest-int.config.ts --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint --fix .",
    "format:write": "prettier --write \"**/*.{js,mjs,cjs,ts,mts,cts,json,yml,yaml,md}\" --cache",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,mts,cts,json,yml,yaml,md}\" --cache",
    "i18n:check": "i18n-check --source en --locales locales",
    "clean": "bash scripts/clean.sh",
    "commit": "commit",
    "prepare": "husky",
    "postinstall": "pnpm build"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/prompt-cli": "^20.5.0",
    "@lingual/i18n-check": "^0.9.3",
    "@types/compression": "^1.8.1",
    "@types/connect-timeout": "^1.9.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cssnano-cli": "^1.0.5",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^19.6.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-sort-imports": "^1.8.11",
    "supertest": "^7.2.2",
    "terser": "^5.46.1",
    "ts-jest": "^29.4.6",
    "tsc-files": "^1.1.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "i18next": "^25.10.10",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1"
    }
  }
}
